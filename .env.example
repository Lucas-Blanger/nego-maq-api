# Banco de dados
DATABASE_USER=seu_usuario
DATABASE_PASSWORD=sua_senha
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=seu_banco

# Segurança
ADMIN_TOKEN=sua_chave_admin
SECRET_KEY=sua_chave_secreta

# URLs da aplicação
FRONTEND_URL=http://localhost:9000
API_BASE_URL=http://localhost:5000

# Mercado Pago (SANDBOX)
MERCADO_PAGO_TOKEN=seu_token_mercado_pago
MERCADO_PAGO_PUBLIC_KEY=sua_public_key_mercado_pago
MERCADO_PAGO_WEBHOOK_SECRET=seu_webhook_secret

# Melhor Envio (SANDBOX)
MELHOR_ENVIO_TOKEN=seu_token_melhor_envio
MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br/api/v2

# Dados da empresa (para cálculo de frete e etiquetas)
EMPRESA_NOME=Sua Empresa LTDA
